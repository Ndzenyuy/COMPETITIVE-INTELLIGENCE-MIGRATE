# PostgreSQL connection string
# Replace with your RDS endpoint after terraform apply
DATABASE_URL=postgresql://postgres:yourpassword@your-rds-endpoint.rds.amazonaws.com:5432/competitive_intelligence

# ChromaDB path — set to EFS mount path in ECS task env vars
# For local development, leave as default (./chroma_data)
CHROMA_PATH=./chroma_data

# AWS region (must match your Bedrock region)
AWS_DEFAULT_REGION=us-east-1

# Note: AWS credentials are NOT stored here in production.
# ECS tasks use an IAM task role (auto-detected by boto3).
# For local development only:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
